 size_t sos_write(void *vData, size_t count)
 {
     //implement this to use your syscall
-    return sos_debug_print(vData, count);
+   // return sos_debug_print(vData, count);
+    size_t length;
+    size_t written = 0;
+
+    seL4_MessageInfo_t tag;
+    const unsigned int maxlenght = (seL4_MsgMaxLength - 2)*sizeof(seL4_Word);
+    const char *s = (char*)vData;
+
+    for (length = count; count > 0; count = count - length) {
+        if (length > maxlenght) {
+            length = maxlenght;
+        }
+        tag = seL4_MessageInfo_new(0, 0, 0, (length + sizeof(seL4_Word) - 1) / sizeof(seL4_Word) + 2);
+
+        seL4_SetMR(0, SOS_SYSCALL_WRITE);
+        seL4_SetMR(1, length);
+
+        memcpy(&seL4_GetIPCBuffer()->msg[2],&s[written], length);
+        seL4_Call(SYSCALL_ENDPOINT_SLOT, tag);
+        written += seL4_GetMR(0);
+    }
+    return written;
 }

 size_t sos_read(void *vData, size_t count)
